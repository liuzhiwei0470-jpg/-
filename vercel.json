{
  "buildCommand": "cd views/frontend && npm run build",
  "outputDirectory": "views/frontend/dist",
  "installCommand": "npm install && cd views/frontend && npm install",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "serverless": {
    "node": "20"
  }
}
